'use client';

import { useAuthStore } from '@/stores/auth-store';
import { useOrgStore } from '@/stores/org-store';
import { Avatar } from '@/components/ui/avatar';
import { Badge } from '@/components/ui/badge';
import { MOCK_PROFILES } from '@/lib/mock/data';

export const Header = () => {
  const { user, role, switchUser } = useAuthStore();
  const organization = useOrgStore((s) => s.organization);

  return (
    <header className="flex h-14 items-center justify-between border-b-2 border-black bg-white px-6">
      {/* Left: Page context */}
      <div className="flex items-center gap-3">
        <h2 className="text-sm font-black uppercase tracking-wider text-black">
          {organization?.name ?? 'MarketBoard'}
        </h2>
      </div>

      {/* Right: Dev role switcher + user */}
      <div className="flex items-center gap-4">
        {/* Dev-only role switcher */}
        <div className="flex items-center gap-2">
          <span className="text-xs text-neutral-400">Switch:</span>
          <select
            value={user?.id ?? ''}
            onChange={(e) => switchUser(e.target.value)}
            className="border border-neutral-300 bg-white px-2 py-1 text-xs text-black outline-none"
            aria-label="Switch user for testing"
          >
            {MOCK_PROFILES.map((p) => (
              <option key={p.id} value={p.id}>
                {p.full_name}
              </option>
            ))}
          </select>
        </div>

        <Badge variant="outline">{role}</Badge>

        {user && (
          <div className="flex items-center gap-2">
            <Avatar name={user.full_name} src={user.avatar_url} size="sm" />
          </div>
        )}
      </div>
    </header>
  );
};
