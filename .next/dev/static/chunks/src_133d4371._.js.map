'use client';

import { Card } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { EmptyState } from '@/components/ui/empty-state';
import { AccessDenied } from '@/components/shared/access-denied';
import { useAuthStore } from '@/stores/auth-store';
import { hasPermission } from '@/lib/constants/roles';
import { MOCK_TASKS, getProfile } from '@/lib/mock/data';

export default function ApprovalsPage() {
  const role = useAuthStore((s) => s.role);

  if (!hasPermission(role, 'task:approve_requests')) {
    return <AccessDenied message="Only managers, admins, and owners can view the approval queue." />;
  }

  const pendingTasks = MOCK_TASKS.filter((t) => t.request_status === 'pending' && !t.is_deleted);

  return (
    <div>
      <div className="mb-6">
        <h1 className="text-2xl font-black tracking-tight text-black">Approval Queue</h1>
        <p className="text-sm text-neutral-500">
          {pendingTasks.length} request{pendingTasks.length !== 1 ? 's' : ''} waiting for review
        </p>
      </div>

      {pendingTasks.length === 0 ? (
        <EmptyState
          title="All Clear"
          description="No pending requests to review. Your team is running smoothly."
          icon={
            <svg className="h-6 w-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          }
        />
      ) : (
        <div className="space-y-3">
          {pendingTasks.map((task) => {
            const requester = task.requested_by ? getProfile(task.requested_by) : null;

            return (
              <Card key={task.id} padding="md" shadow={false}>
                <div className="flex items-center justify-between">
                  <div>
                    <div className="mb-1 flex items-center gap-2">
                      <Badge color="warning" variant="outline">Pending</Badge>
                      <h3 className="text-sm font-bold text-black">{task.title}</h3>
                    </div>
                    <p className="text-xs text-neutral-400">
                      Requested by {requester?.full_name ?? 'Unknown'}
                      {' · '}
                      {new Date(task.created_at).toLocaleDateString('en-IN', { month: 'short', day: 'numeric' })}
                    </p>
                  </div>
                  <div className="flex gap-2">
                    <Button size="sm" variant="secondary">Reject</Button>
                    <Button size="sm">Approve</Button>
                  </div>
                </div>
              </Card>
            );
          })}
        </div>
      )}
    </div>
  );
}
