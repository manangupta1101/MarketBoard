'use client';

import type { CreativeRequest, RequestStatus, RequestPriority } from '@/types';
import { REQUEST_STATUS_LABELS, REQUEST_STATUS_ORDER, PRIORITY_CONFIG } from '@/types';
import { Card } from '@/components/ui/card';

interface DashboardViewProps {
  requests: CreativeRequest[];
}

const STATUS_COLORS: Record<RequestStatus, string> = {
  open: 'text-blue-600 bg-blue-50',
  in_progress: 'text-amber-600 bg-amber-50',
  review: 'text-violet-600 bg-violet-50',
  closed: 'text-emerald-600 bg-emerald-50',
};

export const DashboardView = ({ requests }: DashboardViewProps) => {
  // Status counts
  const statusCounts = REQUEST_STATUS_ORDER.reduce(
    (acc, status) => {
      acc[status] = requests.filter((r) => r.status === status).length;
      return acc;
    },
    {} as Record<RequestStatus, number>
  );

  // Priority counts
  const priorityCounts = (['urgent', 'high', 'medium', 'low'] as RequestPriority[]).reduce(
    (acc, p) => {
      acc[p] = requests.filter((r) => r.priority === p).length;
      return acc;
    },
    {} as Record<RequestPriority, number>
  );

  // Top assignees
  const assigneeCounts: Record<string, number> = {};
  for (const r of requests) {
    if (r.assigneeName) {
      assigneeCounts[r.assigneeName] = (assigneeCounts[r.assigneeName] || 0) + 1;
    }
  }
  const topAssignees = Object.entries(assigneeCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 6);

  // Top requesters
  const requesterCounts: Record<string, number> = {};
  for (const r of requests) {
    requesterCounts[r.requesterName] = (requesterCounts[r.requesterName] || 0) + 1;
  }
  const topRequesters = Object.entries(requesterCounts)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 6);

  // Unassigned count
  const unassigned = requests.filter((r) => !r.assigneeId && r.status !== 'closed').length;

  return (
    <div className="space-y-6">
      {/* Summary Row */}
      <div className="grid grid-cols-2 gap-4 sm:grid-cols-4">
        {REQUEST_STATUS_ORDER.map((status) => (
          <Card key={status} padding="md" shadow={false}>
            <div className="flex items-center gap-3">
              <div className={`flex h-10 w-10 items-center justify-center rounded-[var(--radius-md)] ${STATUS_COLORS[status]}`}>
                <span className="text-lg font-bold">{statusCounts[status]}</span>
              </div>
              <div>
                <p className="text-xs text-[var(--text-tertiary)]">Requests</p>
                <p className="text-sm font-semibold text-[var(--text-primary)]">
                  {REQUEST_STATUS_LABELS[status]}
                </p>
              </div>
            </div>
          </Card>
        ))}
      </div>

      {/* Overview Row */}
      <div className="grid grid-cols-3 gap-4">
        <Card padding="md" shadow={false}>
          <p className="text-xs text-[var(--text-tertiary)]">Total requests</p>
          <p className="mt-1 text-2xl font-bold text-[var(--text-primary)]">{requests.length}</p>
        </Card>
        <Card padding="md" shadow={false}>
          <p className="text-xs text-[var(--text-tertiary)]">Active (non-closed)</p>
          <p className="mt-1 text-2xl font-bold text-[var(--primary)]">
            {requests.length - statusCounts.closed}
          </p>
        </Card>
        <Card padding="md" shadow={false}>
          <p className="text-xs text-[var(--text-tertiary)]">Unassigned</p>
          <p className="mt-1 text-2xl font-bold text-[var(--warning)]">{unassigned}</p>
        </Card>
      </div>

      {/* Priority + Assignees */}
      <div className="grid gap-6 md:grid-cols-2">
        {/* Priority Breakdown */}
        <Card padding="md">
          <h3 className="mb-4 text-sm font-semibold text-[var(--text-primary)]">By Priority</h3>
          <div className="space-y-3">
            {(['urgent', 'high', 'medium', 'low'] as RequestPriority[]).map((p) => {
              const count = priorityCounts[p];
              const total = requests.length || 1;
              const pct = Math.round((count / total) * 100);
              const cfg = PRIORITY_CONFIG[p];
              const barColor =
                p === 'urgent' ? 'bg-red-500' : p === 'high' ? 'bg-amber-500' : p === 'medium' ? 'bg-blue-500' : 'bg-gray-400';

              return (
                <div key={p}>
                  <div className="mb-1 flex items-center justify-between">
                    <span className="text-xs font-medium capitalize text-[var(--text-primary)]">{cfg.label}</span>
                    <span className="text-xs text-[var(--text-tertiary)]">{count} ({pct}%)</span>
                  </div>
                  <div className="h-2 w-full rounded-full bg-[var(--surface-secondary)]">
                    <div className={`h-2 rounded-full ${barColor}`} style={{ width: `${pct}%` }} />
                  </div>
                </div>
              );
            })}
          </div>
        </Card>

        {/* Top Assignees */}
        <Card padding="md">
          <h3 className="mb-4 text-sm font-semibold text-[var(--text-primary)]">Top Assignees</h3>
          {topAssignees.length === 0 ? (
            <p className="text-sm text-[var(--text-tertiary)]">No assignments yet</p>
          ) : (
            <div className="space-y-2.5">
              {topAssignees.map(([name, count]) => (
                <div key={name} className="flex items-center justify-between">
                  <span className="text-sm text-[var(--text-primary)]">{name}</span>
                  <span className="flex h-5 min-w-[20px] items-center justify-center rounded-full bg-[var(--surface-secondary)] px-1.5 text-xs font-medium text-[var(--text-secondary)]">
                    {count}
                  </span>
                </div>
              ))}
            </div>
          )}
        </Card>
      </div>

      {/* Top Requesters */}
      <Card padding="md">
        <h3 className="mb-4 text-sm font-semibold text-[var(--text-primary)]">Top Requesters</h3>
        <div className="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
          {topRequesters.map(([name, count]) => (
            <div key={name} className="flex items-center justify-between rounded-[var(--radius-md)] bg-[var(--surface-secondary)] px-3 py-2">
              <span className="text-sm text-[var(--text-primary)]">{name}</span>
              <span className="text-xs font-medium text-[var(--text-secondary)]">{count} requests</span>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );
};
