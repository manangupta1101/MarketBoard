'use client';

import { Card } from '@/components/ui/card';
import { Input } from '@/components/ui/input';
import { Button } from '@/components/ui/button';
import { Divider } from '@/components/ui/divider';
import { AccessDenied } from '@/components/shared/access-denied';
import { useAuthStore } from '@/stores/auth-store';
import { useOrgStore } from '@/stores/org-store';
import { hasPermission } from '@/lib/constants/roles';

export default function SettingsPage() {
  const role = useAuthStore((s) => s.role);
  const organization = useOrgStore((s) => s.organization);

  if (!hasPermission(role, 'org:manage_settings')) {
    return <AccessDenied message="Only owners and admins can manage organization settings." />;
  }

  return (
    <div>
      <div className="mb-6">
        <h1 className="text-2xl font-black tracking-tight text-black">Settings</h1>
        <p className="text-sm text-neutral-500">Manage your organization</p>
      </div>

      <Card className="max-w-lg">
        <h2 className="mb-4 text-lg font-black text-black">Organization</h2>
        <div className="space-y-4">
          <Input
            label="Organization Name"
            defaultValue={organization?.name ?? ''}
            placeholder="Your organization name"
          />
          <Input
            label="Slug"
            defaultValue={organization?.slug ?? ''}
            placeholder="url-friendly-name"
          />
        </div>

        <Divider />

        <div className="flex gap-3">
          <Button size="sm">Save Changes</Button>
          <Button size="sm" variant="secondary">Cancel</Button>
        </div>
      </Card>
    </div>
  );
}
