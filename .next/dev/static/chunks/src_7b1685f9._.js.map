'use client';

import { Card } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { EmptyState } from '@/components/ui/empty-state';
import { useAuthStore } from '@/stores/auth-store';
import { MOCK_TASKS, MOCK_BOARD_COLUMNS } from '@/lib/mock/data';

export default function MyTasksPage() {
  const user = useAuthStore((s) => s.user);

  const myTasks = MOCK_TASKS.filter(
    (t) => t.assigned_to === user?.id && !t.is_deleted
  );

  const getColumnName = (columnId: string) =>
    MOCK_BOARD_COLUMNS.find((c) => c.id === columnId)?.name ?? 'Unknown';

  if (myTasks.length === 0) {
    return (
      <div>
        <h1 className="mb-6 text-2xl font-black tracking-tight text-black">My Tasks</h1>
        <EmptyState
          title="No Tasks Assigned"
          description="You don't have any tasks assigned to you yet."
          icon={
            <svg className="h-6 w-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          }
        />
      </div>
    );
  }

  return (
    <div>
      <div className="mb-6">
        <h1 className="text-2xl font-black tracking-tight text-black">My Tasks</h1>
        <p className="text-sm text-neutral-500">{myTasks.length} tasks assigned to you</p>
      </div>

      <div className="space-y-3">
        {myTasks.map((task) => (
          <Card key={task.id} padding="md" shadow={false} className="hover:shadow-[3px_3px_0px_0px_#000] transition-shadow cursor-pointer">
            <div className="flex items-center justify-between">
              <div>
                <div className="mb-1 flex items-center gap-2">
                  <h3 className="text-sm font-bold text-black">{task.title}</h3>
                  <Badge variant="outline">{task.priority}</Badge>
                </div>
                <div className="flex items-center gap-3 text-xs text-neutral-400">
                  <span>{getColumnName(task.column_id)}</span>
                  {task.due_date && (
                    <span>Due {new Date(task.due_date).toLocaleDateString('en-IN', { month: 'short', day: 'numeric' })}</span>
                  )}
                  {task.estimated_hours && (
                    <span>{task.estimated_hours}h estimated</span>
                  )}
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  );
}
