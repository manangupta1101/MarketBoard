{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/board/layout,_N_T_/(app)/board/page,_N_T_/board"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/board/__PAGE__",
    "/!KGFwcCk/board",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}